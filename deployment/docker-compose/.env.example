# ---------- Images ----------
AGENTSPAN_IMAGE=agentspan/server:latest
POSTGRES_IMAGE=postgres:16-alpine

# ---------- Ports ----------
AGENTSPAN_PORT=6767
POSTGRES_PORT=5432

# ---------- Database (bundled postgres service) ----------
POSTGRES_HOST=postgres
POSTGRES_DB=agentspan
POSTGRES_USER=agentspan
POSTGRES_PASSWORD=changeme

# ---------- Runtime tuning ----------
SPRING_PROFILES_ACTIVE=postgres
JAVA_TOOL_OPTIONS=-Xms512m -Xmx1536m -XX:+UseG1GC -XX:MaxGCPauseMillis=200
LOGGING_LEVEL_ROOT=WARN
LOGGING_LEVEL_DEV_AGENTSPAN=INFO

# Optional local Ollama endpoint (container reaches host via host.docker.internal)
OLLAMA_HOST=http://host.docker.internal:11434

# ---------- Encryption ----------
# Master key for credential encryption (AES-256-GCM, base64-encoded 32 bytes)
# Generate with: openssl rand -base64 32
AGENTSPAN_MASTER_KEY=

# ---------- LLM provider credentials (set at least one) ----------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
